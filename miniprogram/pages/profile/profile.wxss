/* 个人中心页面样式 */

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-icon {
  font-size: 60rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 8rpx;
}

.user-role {
  font-size: 24rpx;
  color: #999999;
}

.login-btn,
.logout-btn {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
}

.login-btn {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
}

.logout-btn {
  background: #f5f5f5;
}

.login-text {
  font-size: 28rpx;
  color: #ffffff;
}

.logout-text {
  font-size: 28rpx;
  color: #666666;
}

/* 小区信息 */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.community-info {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.community-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.community-address {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 菜单卡片 */
.menu-card {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 20rpx;
}

.menu-icon.bill {
  background: #f9f0ff;
}

.menu-icon.inquiry {
  background: #fff7e6;
}

.menu-icon.vote {
  background: #f6ffed;
}

.menu-icon.settings {
  background: #e6f7ff;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-badge {
  min-width: 36rpx;
  height: 36rpx;
  background: #f5222d;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #ffffff;
  margin-right: 16rpx;
  padding: 0 12rpx;
}

/* 联系列表 */
.contact-list {
  padding: 0 20rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.contact-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.contact-value {
  font-size: 28rpx;
  color: #1890ff;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx 0 60rpx;
}

.version-text {
  font-size: 24rpx;
  color: #cccccc;
}