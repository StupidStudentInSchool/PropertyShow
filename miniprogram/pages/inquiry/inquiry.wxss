/* 质询页面样式 */

/* 质询项 */
.inquiry-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.inquiry-item:last-child {
  border-bottom: none;
}

.inquiry-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.inquiry-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.inquiry-tag.PENDING {
  background: #fff7e6;
  color: #fa8c16;
}

.inquiry-tag.REPLIED {
  background: #f6ffed;
  color: #52c41a;
}

.inquiry-tag.CLOSED {
  background: #f5f5f5;
  color: #999999;
}

.inquiry-tag.REJECTED {
  background: #fff2f0;
  color: #f5222d;
}

.inquiry-time {
  font-size: 22rpx;
  color: #999999;
}

.inquiry-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.inquiry-content {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.inquiry-author {
  font-size: 24rpx;
  color: #999999;
}

.inquiry-footer {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-top: 12rpx;
}

.reply-info {
  display: flex;
  flex-direction: column;
}

.reply-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.reply-text {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.5;
}

.reply-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 12rpx;
}

.pending-text {
  font-size: 26rpx;
  color: #fa8c16;
}